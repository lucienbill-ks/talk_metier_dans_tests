to j_initialise_le_systeme
	logfct
	// Fermer Chrome
	"02_lib/system".je_lance_une_commande_windows_r "taskkill /F /IM chrome.exe /T"
	wait 1 
	WaitForNotFound 15, "chrome/icone_chargement"
	
	// Fermer Keepass s'il est ouvert
	"02_lib/keepass".je_quitte_keepass_si_ouvert
	
	logfct
end j_initialise_le_systeme